# ============================================
# OpsTwin AI — Backend Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Splunk Enterprise ---
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_HEC_PORT=8088
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=YourSplunkPassword
SPLUNK_HEC_TOKEN=your-hec-token-here

# --- LLM (Groq — free at https://console.groq.com/keys) ---
OPENAI_API_KEY=gsk_your-groq-api-key
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Database (Neon PostgreSQL — free at https://neon.tech) ---
DATABASE_URL=postgresql://user:password@your-project.neon.tech/neondb?sslmode=require

# --- JWT Auth ---
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
